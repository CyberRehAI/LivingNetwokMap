PORT=3000
WEBSOCKET_PORT=3001
NODE_ENV=development

# Health check settings
HEALTH_CHECK_INTERVAL=10000
NODE_TIMEOUT=10000

# Redis (optional)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379

# Network scanning
AUTO_DISCOVERY=false
SCAN_SUBNET=192.168.1.0/24

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/server.log

# CORS
CORS_ORIGIN=http://localhost:5173
